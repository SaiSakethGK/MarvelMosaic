# Django core
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Marvel API credentials
# Get yours at: https://developer.marvel.com
MARVEL_PUBLIC_KEY=your-marvel-public-key-here
MARVEL_PRIVATE_KEY=your-marvel-private-key-here

# Zapier webhook (optional — used for email notifications)
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/your-id/your-key/

# Database (defaults to SQLite for local dev)
# Uncomment and set for PostgreSQL in production:
# DATABASE_URL=postgres://user:password@host:5432/dbname
